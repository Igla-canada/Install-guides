{
  "name": "igla-guilds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "token:service": "tsx scripts/create-service-token.ts",
    "import:notion": "tsx --env-file=.env scripts/import-notion.ts",
    "import:ghost": "tsx --env-file=.env scripts/import-ghost.ts",
    "compat:seed": "tsx --env-file=.env scripts/seed-vehicle-compatibility.ts",
    "compat:refresh": "tsx --env-file=.env scripts/seed-vehicle-compatibility.ts --refresh",
    "import:ghost:all": "tsx --env-file=.env scripts/import-ghost.ts --all",
    "import:ghost:repair": "tsx --env-file=.env scripts/import-ghost.ts --all --replace"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.11",
    "html2canvas-pro": "^2.0.4",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "next": "16.2.9",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
